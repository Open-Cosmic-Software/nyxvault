# ───────────────────────────────────────────────────────────
# NyxVault Configuration — copy to .env and fill in real values
# ───────────────────────────────────────────────────────────

# Port the server listens on (bound to 127.0.0.1)
PORT=3870

# API key for the upload API / CLI (generate a long random string)
#   e.g. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=change-me-generate-a-long-random-string

# Password for the web upload UI (plaintext, or an argon2 hash starting with $argon2)
WEB_PASSWORD=change-me

# Maximum upload size in megabytes
MAX_FILE_SIZE_MB=100

# Optional: VirusTotal API key to enable the privacy-preserving hash scan
# (only the SHA-256 hash of the decrypted file is ever sent to VirusTotal —
#  never the file itself). Leave empty to disable the feature.
VT_API_KEY=

# WebAuthn / Passkey configuration (optional passkey-based encryption)
#   RP ID = your public hostname, ORIGIN = full https origin. Must match Caddy.
WEBAUTHN_RP_ID=nyxvault.org
WEBAUTHN_RP_NAME=NyxVault
WEBAUTHN_ORIGIN=https://nyxvault.org
